{
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk-poetry",
      "command": "bash",
      "args": [
        "%DIR%/../../scripts/latex/latexmk.sh",
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-pdf",
        "-shell-escape",
        "-f",
        "%DOC%"
      ]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk (pdflatex + shell-escape + pygments)",
      "tools": ["latexmk-poetry"]
    }
  ],
  "latex-workshop.latex.recipe.default": "latexmk (pdflatex + shell-escape + pygments)",
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.clean.fileTypes": [
    "*.aux",
    "*.bbl",
    "*.blg",
    "*.idx",
    "*.ind",
    "*.lof",
    "*.lot",
    "*.out",
    "*.toc",
    "*.acn",
    "*.acr",
    "*.alg",
    "*.glg",
    "*.glo",
    "*.gls",
    "*.fls",
    "*.log",
    "*.fdb_latexmk",
    "*.snm",
    "*.synctex(busy)",
    "*.synctex.gz",
    "*.nav",
    "*.vrb",
    "*.bcf",
    "*.run.xml",
    "_minted/**"
  ]
}
